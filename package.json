{
  "name": "error-hammer",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "content:validate": "tsx scripts/content_validate.ts",
    "content:compile": "tsx scripts/content_compile.ts",
    "benchmark:progression": "tsx scripts/benchmark_progression.ts",
    "itch:zip": "tsx scripts/package_itch.ts",
    "build:itch": "npm run content:compile && npm run build && npm run itch:zip",
    "release:prepare": "tsx scripts/release_prepare.ts",
    "release:verify": "tsx scripts/release_verify.ts",
    "release:finalize": "tsx scripts/release_finalize.ts",
    "release:itch": "npm run release:prepare && npm run release:verify && npm run release:finalize"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.15.21",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "ajv": "^8.17.1",
    "jsdom": "^28.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vite": "^5.4.19",
    "vitest": "^2.1.9"
  }
}
