{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "minItems": 10,
  "maxItems": 10,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["id", "name", "weights", "flavorLines"],
    "properties": {
      "id": { "type": "string", "minLength": 2 },
      "name": { "type": "string", "minLength": 2 },
      "weights": {
        "type": "object",
        "additionalProperties": false,
        "required": ["wCash", "wRep", "wRiskAvoid", "wToolBuy"],
        "properties": {
          "wCash": { "type": "number", "minimum": 0 },
          "wRep": { "type": "number", "minimum": 0 },
          "wRiskAvoid": { "type": "number", "minimum": 0 },
          "wToolBuy": { "type": "number", "minimum": 0 }
        }
      },
      "flavorLines": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "minLength": 2 }
      }
    }
  }
}
