{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "minItems": 8,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "name",
      "primarySkill",
      "tier",
      "districtId",
      "requiredTools",
      "staminaCost",
      "basePayout",
      "risk",
      "repGainSuccess",
      "repLossFail",
      "durabilityCost",
      "tags",
      "flavor"
    ],
    "properties": {
      "id": { "type": "string", "minLength": 2 },
      "name": { "type": "string", "minLength": 2 },
      "primarySkill": {
        "type": "string",
        "enum": [
          "electrician",
          "plumber",
          "carpenter",
          "mason",
          "concrete_finisher",
          "roofer",
          "hvac_technician",
          "drywall_installer",
          "painter",
          "flooring_installer",
          "glazier",
          "insulation_installer",
          "framer",
          "siding_installer",
          "fence_installer",
          "cabinet_maker",
          "millworker",
          "scaffolder",
          "solar_panel_installer"
        ]
      },
      "tier": { "type": "integer", "minimum": 1, "maximum": 5 },
      "districtId": { "type": "string", "minLength": 2 },
      "requiredTools": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "minLength": 2 }
      },
      "staminaCost": { "type": "integer", "minimum": 1, "maximum": 10 },
      "basePayout": { "type": "integer", "minimum": 10 },
      "risk": { "type": "number", "minimum": 0, "maximum": 1 },
      "repGainSuccess": { "type": "integer", "minimum": 0 },
      "repLossFail": { "type": "integer", "minimum": 0 },
      "durabilityCost": { "type": "integer", "minimum": 1, "maximum": 20 },
      "workUnits": { "type": "integer", "minimum": 1, "maximum": 20 },
      "materialNeeds": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["supplyId", "quantity"],
          "properties": {
            "supplyId": { "type": "string", "minLength": 2 },
            "quantity": { "type": "integer", "minimum": 1, "maximum": 20 }
          }
        }
      },
      "tags": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "minLength": 2 }
      },
      "flavor": {
        "type": "object",
        "additionalProperties": false,
        "required": ["client_quote", "success_line", "fail_line", "neutral_line"],
        "properties": {
          "client_quote": { "type": "string", "minLength": 2 },
          "success_line": { "type": "string", "minLength": 2 },
          "fail_line": { "type": "string", "minLength": 2 },
          "neutral_line": { "type": "string", "minLength": 2 }
        }
      }
    }
  }
}
